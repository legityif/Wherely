# Copy this file to .env.local and fill in your values.
# EXPO_PUBLIC_* variables are embedded in the client bundle.
# Never put secret API keys in EXPO_PUBLIC_* variables.

# Supabase (safe to expose — protected by RLS)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase Edge Function secrets (set via: supabase secrets set KEY=value) ──
# GOOGLE_PLACES_API_KEY=your-google-places-api-key
# GEMINI_API_KEY=your-gemini-api-key        (optional — falls back to template)
